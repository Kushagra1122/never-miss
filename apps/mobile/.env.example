# Copied to apps/mobile/.env — loaded when you run Expo from apps/mobile.
# Physical phone: use your Mac/PC LAN IP (same Wi‑Fi), NOT 127.0.0.1.
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.42:3000
#
# Must match API_PUBLIC_URL in the repo root .env (Google OAuth redirect).
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
