# API (services/api) — Docker Postgres is mapped to host port 5433 (see docker-compose.yml)
DATABASE_URL=postgres://nevermiss:nevermiss@127.0.0.1:5433/nevermiss
JWT_SECRET=change-me-min-16-chars-long-secret
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# OAuth redirect base (must match Google Cloud “Authorized redirect URIs”).
# Simulator/emulator on same machine: http://127.0.0.1:3000
# Physical phone: Google blocks bare private IPs (10.x / 192.168.x) — use either:
#   • nip.io: http://YOUR_LAN_IP.nip.io:3000  (DNS resolves to your IP; no extra install)
#   • ngrok: https://YOUR_SUBDOMAIN.ngrok-free.app  (HTTPS; run: ngrok http 3000)
API_PUBLIC_URL=http://127.0.0.1:3000
MOBILE_APP_SCHEME=nevermiss
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PORT=3000
POLL_INTERVAL_MS=120000
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=1 minute

# Same origin as API_PUBLIC_URL (Expo reads at bundle time).
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
